{
  "uid": "hal-ollama",
  "title": "Ollama Inference",
  "tags": ["hal-10k", "ollama", "ai"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Requests/s",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(ollama_request_duration_seconds_count[5m]))", "legendFormat": "req/s" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2, "type": "stat", "title": "P95 Latency",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(ollama_request_duration_seconds_bucket[5m])) by (le, model))", "legendFormat": "{{model}} p95" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3, "type": "stat", "title": "Tokens/s",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(ollama_tokens_total[5m]))", "legendFormat": "tok/s" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 4, "type": "timeseries", "title": "Request Rate by Model",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by(model) (rate(ollama_request_duration_seconds_count[5m]))", "legendFormat": "{{model}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Inference Latency by Model",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(ollama_request_duration_seconds_bucket[5m])) by (le, model))", "legendFormat": "{{model}} p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(ollama_request_duration_seconds_bucket[5m])) by (le, model))", "legendFormat": "{{model}} p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6, "type": "logs", "title": "Ollama Logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{container_name=\"ollama\"}", "legendFormat": "" }],
      "options": { "dedupStrategy": "none", "showLabels": false, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ],
  "templating": {
    "list": [
      { "name": "DS_PROMETHEUS", "type": "datasource", "pluginId": "prometheus", "current": { "text": "Prometheus", "value": "Prometheus" } },
      { "name": "DS_LOKI", "type": "datasource", "pluginId": "loki", "current": { "text": "Loki", "value": "Loki" } }
    ]
  }
}
