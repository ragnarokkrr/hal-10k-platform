# compose/observability/.env.example
#
# Environment variables required by the observability stack.
# Secrets are managed via SOPS-encrypted `secrets/observability.enc.yaml`.
# At runtime, the decrypted file is loaded from /srv/platform/secrets/observability.yaml.
#
# To prepare runtime secrets:
#   1. export SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt
#   2. ./scripts/secrets-decrypt.sh observability
#
# Then update the real value in /srv/platform/secrets/observability.yaml before first deploy:
#   - GF_SECURITY_ADMIN_PASSWORD: choose a strong password for the Grafana admin account
# Re-encrypt when values change:
#   sops --encrypt --in-place secrets/observability.enc.yaml
#
# NEVER commit the decrypted file or any file containing real values.

# --- Grafana Admin ---
GF_SECURITY_ADMIN_USER=admin
# GF_SECURITY_ADMIN_PASSWORD is sourced from secrets/observability.yaml (SOPS-managed)

# --- Loki ---
# Log retention period. Default: 30 days.
LOKI_RETENTION_PERIOD=30d

# --- Image Tags (pin to specific versions before deploying) ---
PROMETHEUS_IMAGE=prom/prometheus:v3.2.1
GRAFANA_IMAGE=grafana/grafana:11.6.0
LOKI_IMAGE=grafana/loki:3.4.2
NODE_EXPORTER_IMAGE=prom/node-exporter:v1.9.1
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor:v0.52.0
