# AI stack (Ollama + LiteLLM + Open WebUI) — environment variables
# Copy to .env and fill in values (never commit .env)

# LiteLLM
LITELLM_MASTER_KEY=sk-REPLACE_ME
LITELLM_SALT_KEY=REPLACE_ME_RANDOM

# Open WebUI
WEBUI_SECRET_KEY=REPLACE_ME_RANDOM

# Ollama (default port)
OLLAMA_BASE_URL=http://ollama:11434

# ROCm GPU
HSA_OVERRIDE_GFX_VERSION=11.0.0
ROCR_VISIBLE_DEVICES=0
