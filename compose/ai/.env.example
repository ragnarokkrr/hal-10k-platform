# compose/ai/.env.example
#
# Environment variables required by the AI inference stack.
# Secrets are managed via SOPS-encrypted `secrets/ai.enc.yaml`.
# At runtime, the decrypted file is loaded from /srv/platform/secrets/ai.yaml.
#
# To prepare runtime secrets:
#   1. export SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt
#   2. ./scripts/secrets-decrypt.sh ai
#
# Then update the real values in /srv/platform/secrets/ai.yaml before first deploy:
#   - LITELLM_MASTER_KEY: generate with `openssl rand -hex 32`, prefix with "sk-"
#   - LITELLM_SECRET_KEY: generate with `openssl rand -hex 32`
#   - OPENAI_API_KEY:     set to the same value as LITELLM_MASTER_KEY
#   - WEBUI_SECRET_KEY:   generate with `openssl rand -hex 32`
# Re-encrypt when values change:
#   sops --encrypt --in-place secrets/ai.enc.yaml
#
# NEVER commit the decrypted file or any file containing real values.

# --- LiteLLM Master Key ---
# Bearer token required for all LiteLLM API requests.
# Format: "sk-<random-hex>" (e.g. sk-abc123...)
# Generate: openssl rand -hex 32 | sed 's/^/sk-/'
LITELLM_MASTER_KEY=sk-CHANGEME

# --- LiteLLM Secret Key ---
# Internal signing key used by LiteLLM for JWT generation.
# Generate: openssl rand -hex 32
LITELLM_SECRET_KEY=CHANGEME

# --- Open WebUI API Key ---
# Must match LITELLM_MASTER_KEY — used by Open WebUI to call the LiteLLM backend.
OPENAI_API_KEY=sk-CHANGEME

# --- Open WebUI Session Secret ---
# Used to sign Open WebUI session tokens. Keep secret; rotate if compromised.
# Generate: openssl rand -hex 32
WEBUI_SECRET_KEY=CHANGEME

# --- Image Tags (pin to specific versions before deploying) ---
OLLAMA_IMAGE=ollama/ollama:0.18.0-rocm
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-v1.81.12-stable.1
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:v0.8.10
