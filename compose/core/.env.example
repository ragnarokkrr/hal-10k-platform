# Traefik core stack — environment variables
# Copy to .env and fill in values (never commit .env)

# Traefik dashboard credentials (htpasswd format)
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD_HASH=

# Let's Encrypt / ACME (optional for LAN-only)
ACME_EMAIL=

# Internal domain
HAL10K_DOMAIN=hal-10k.local
