# compose/core/.env.example
#
# Environment variables required by the Traefik core stack.
# Secrets are managed via SOPS-encrypted `secrets/core.enc.yaml`.
# At runtime, the decrypted file is loaded from /srv/platform/secrets/core.yaml.
#
# To prepare the runtime secrets:
#   1. export SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt
#   2. ./scripts/secrets-decrypt.sh core
#   3. The decrypted values below will be available in /srv/platform/secrets/core.yaml
#
# NEVER commit the decrypted file or any file containing real values.

# --- Traefik Dashboard ---
# htpasswd-hashed credentials for the BasicAuth middleware.
# Generate with: openssl passwd -apr1 <password>
# Format: user:hashed_password
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$XXXXXXXX$$XXXXXXXXXXXXXXXXXXXX

# --- TLS Certificate (base64-encoded PEM) ---
# Wildcard self-signed certificate for *.hal.local
# Generate with:
#   openssl req -x509 -newkey rsa:4096 -keyout hal-local.key \
#     -out hal-local.crt -days 3650 -nodes \
#     -subj "/CN=*.hal.local/O=HAL-10k/C=US" \
#     -addext "subjectAltName=DNS:*.hal.local,DNS:hal.local"
# Then base64-encode: base64 -w0 hal-local.crt
TRAEFIK_TLS_CERT=<base64-encoded-PEM-certificate>

# --- TLS Private Key (base64-encoded PEM) ---
# Corresponds to TRAEFIK_TLS_CERT above.
# base64-encode: base64 -w0 hal-local.key
TRAEFIK_TLS_KEY=<base64-encoded-PEM-private-key>
