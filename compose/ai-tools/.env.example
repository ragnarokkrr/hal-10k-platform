# compose/ai-tools/.env.example
# Copy to .env and set production values before starting the stack.
# .env is gitignored — never commit plaintext values.

# ── llama.cpp image ───────────────────────────────────────────────────────────
# Pin by digest for reproducibility. Get the digest after pulling:
#   docker inspect --format='{{index .RepoDigests 0}}' ghcr.io/ggml-org/llama.cpp:server-rocm
# To use the floating tag (always latest ROCm build), set:
#   LLAMACPP_IMAGE=ghcr.io/ggml-org/llama.cpp:server-rocm
LLAMACPP_IMAGE=ghcr.io/ggml-org/llama.cpp@sha256:XXXXXXXXXXXXXXXX

# ── Context window ────────────────────────────────────────────────────────────
# Tokens per context. 16384 is sufficient for agentic tool-call sessions and
# keeps all three 32B models within the 96 GB VRAM budget.
# Increase for single-model sessions requiring longer context (up to 64K+).
CTX_SIZE=16384

# ── GPU layer offload ─────────────────────────────────────────────────────────
# Number of model layers to offload to GPU (99 = all layers).
# With 96 GB dedicated VRAM, full offload is feasible for all combinations.
# Reduce if running all three models simultaneously at large context.
N_GPU_LAYERS_QWEN32B=99
N_GPU_LAYERS_DEEPSEEK32B=99
N_GPU_LAYERS_LLAMA70B=99
